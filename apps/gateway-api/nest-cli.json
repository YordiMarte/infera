{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/gateway-api",
  "sourceRoot": "apps/gateway-api/src",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "projects": {
    "gateway-api": {
      "type": "application",
      "root": "apps/gateway-api",
      "entryFile": "main",
      "sourceRoot": "apps/gateway-api/src"
    }
  }
}
